{
  "name": "calendarlllm",
  "version": "1.0.0",
  "main": "index.js",
  "dependencies": {
    "@expo/metro-runtime": "~5.0.5",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/bottom-tabs": "^7.16.2",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/stack": "^7.9.3",
    "date-fns": "^4.4.0",
    "expo": "~53.0.0",
    "expo-status-bar": "~2.2.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-calendars": "^1.1314.0",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "^0.20.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "wait-on": "^8.0.0"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "electron:dev": "concurrently --kill-others \"expo start --web --port 8081\" \"wait-on http://localhost:8081 && electron electron/main.js\"",
    "electron:build": "expo export -p web && electron-builder",
    "electron:build:win": "expo export -p web && electron-builder --win",
    "electron:build:mac": "expo export -p web && electron-builder --mac",
    "electron:build:all": "expo export -p web && electron-builder --win --mac"
  },
  "build": {
    "appId": "com.calendarlllm.app",
    "productName": "CalendarLLM",
    "copyright": "Copyright © 2024 CalendarLLM",
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "assets/icon.png",
      "assets/icon512.png"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "electron-dist"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "assets/icon512.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerLanguages": ["zh_TW", "en_US"],
      "language": "1028"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon": "assets/icon512.png",
      "category": "public.app-category.productivity",
      "darkModeSupport": true
    },
    "dmg": {
      "title": "CalendarLLM",
      "window": { "width": 540, "height": 380 }
    }
  },
  "private": true
}
